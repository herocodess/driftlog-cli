{
  "version": 2,
  "builds": [
    {
      "src": "vercel.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "." }
    }
  ],
  "redirects": [
    {
      "source": "/",
      "destination": "https://raw.githubusercontent.com/herocodess/driftlog-cli/main/install.sh",
      "permanent": false
    }
  ]
}
