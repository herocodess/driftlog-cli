{
  "name": "driftlog",
  "version": "1.0.0",
  "description": "Driftlog CLI — local-first architectural drift detection.",
  "type": "module",
  "main": "./dist/cli.cjs",
  "module": "./dist/cli.js",
  "bin": {
    "driftlog": "./dist/cli.cjs"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup && chmod +x dist/cli.cjs",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@driftlog/tree-sitter-dart": "1.0.4",
    "ci-info": "^4.0.0",
    "commander": "^12.1.0",
    "fast-glob": "^3.3.2",
    "ignore": "^5.3.2",
    "js-yaml": "^4.1.1",
    "ora": "^8.1.0",
    "picocolors": "^1.0.1",
    "re2": "1.23.3",
    "simple-git": "^3.25.0",
    "tree-sitter": "^0.25.0",
    "tree-sitter-typescript": "^0.23.0"
  },
  "devDependencies": {
    "@driftlog/config": "workspace:*",
    "@driftlog/parser": "workspace:*",
    "@driftlog/types": "workspace:*",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.19.37",
    "eslint": "^9.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  },
  "keywords": [
    "architecture",
    "linter",
    "drift",
    "ast",
    "tree-sitter",
    "driftlog"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/herocodess/driftlog-cli"
  },
  "homepage": "https://docs.driftlog.dev",
  "license": "MIT"
}
